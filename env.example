# Copy file này thành .env và điền giá trị thực

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL của backend API (chỉ dùng khi chạy không qua Docker proxy)
VITE_API_URL=/api

# ── Backend ───────────────────────────────────────────────────────────────────
# Môi trường: development | production
ENV=development

# Port backend lắng nghe
PORT=8000

# (Tuỳ chọn) Secret key nếu dùng JWT auth sau này
# SECRET_KEY=your-secret-key-here

# (Tuỳ chọn) Database connection string nếu lưu lịch sử query
# DATABASE_URL=postgresql://user:pass@localhost:5432/propvision
